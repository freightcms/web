{
  "extends": "@tsconfig/create-react-app/tsconfig.json",
  "compilerOptions": {
    "noImplicitAny": true,
    "sourceMap": true,
    "removeComments": true,
    "noEmit": false,
    "jsx": "react",
    "paths": {
      "@components/*": ["./src/components/*"],
      "@features/*": ["./src/features/*"],
      "@hooks/*": ["./src/hooks/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["/node_modules/", "public/**/*", "**/*.spec.ts"]
}
